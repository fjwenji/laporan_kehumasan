# ============================================================
# MAYZ DJPB - DEPLOYMENT ENVIRONMENT EXAMPLE
# ============================================================
# Copy this file to .env.docker.local for Docker deployment
# cp deployment/docker-local/.env.docker.local.example deployment/docker-local/.env.docker.local
# ============================================================

# DATABASE - Ganti dengan credentials server
MYSQL_HOST=mysql-server
MYSQL_PORT=3306
MYSQL_USER=mayz_user
MYSQL_PASSWORD=GENERATE_SECURE_PASSWORD_HERE
MYSQL_DATABASE=mayz_monitoring

# SECURITY - Wajib di-generate ulang untuk production!
SECRET_KEY=GENERATE_WITH_PYTHON: python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_TOKEN_EXPIRE_MINUTES=480

# INSTAGRAM SCRAPING
IG_LOGIN_ENABLED=false
IG_USERNAME=
IG_PASSWORD=
IG_AUTH_STATE_PATH=/app/data/instagram/auth_state.json

# TELEGRAM NOTIFICATIONS
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_NEW_POST=false

# SCRAPER SETTINGS
MAX_POSTS_PER_ACCOUNT=30
MAX_SCROLLS=8
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=4.0

# DEBUGGING
DEBUG=false
LOG_LEVEL=INFO
