# ============================================================
# MAYZ DJPB - ENVIRONMENT SETUP
# ============================================================
#
# COPY FILE INI KE .env DAN ISI DENGAN VALUE ASLI
# COPY THIS FILE TO .env AND FILL WITH REAL VALUES
#
# cp .env.example .env
#
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
MYSQL_DATABASE=mayz_monitoring

# ============================================================
# SECURITY KEYS
# ============================================================
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_MIN_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ============================================================
# INSTAGRAM CREDENTIALS (Optional - untuk scraping private posts)
# ============================================================
IG_LOGIN_ENABLED=false
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password
IG_AUTH_STATE_PATH=data/instagram/auth_state.json

# ============================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE
TELEGRAM_NOTIFY_NEW_POST=true

# ============================================================
# SCRAPER SETTINGS
# ============================================================
MAX_POSTS_PER_ACCOUNT=30
MAX_SCROLLS=8
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=4.0

# ============================================================
# LOGGING
# ============================================================
DEBUG=false
LOG_LEVEL=INFO
