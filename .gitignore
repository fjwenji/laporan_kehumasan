# ============================================================
# MAYZ DJPB - .GITIGNORE
# ============================================================
# File ini sudah DIKONFIGURASI untuk melindungi data sensitif
# File ini SUDAH AMAN untuk push ke GitHub

# ============================================================
# ENVIRONMENT / SECRETS - CRITICAL
# ============================================================
# JANGAN HAPUS INI! File ini melindungi .env dari push
.env
.env.local
.env.production
.env.*.local
!.env.example

# Deployment configs (jika ada secrets nyata)
deployment/docker-local/.env.docker.local
deployment/docker-local/.env.local
deployment/docker-local/.env.production

# ============================================================
# INSTAGRAM SESSION / COOKIES
# ============================================================
# Session Instagram bisa mengandung credentials
data/instagram/
**/auth_state.json
**/storage_state.json
**/*.session

